       fhir:ElementDefinition.short [ fhir:value "Supplemental instruction or warnings to the patient - e.g. \"with meals\", \"may cause drowsiness\"" ] ;
       fhir:ElementDefinition.definition [ fhir:value "Supplemental instructions to the patient on how to take the medication  (e.g. \"with meals\" or\"take half to one hour before food\") or warnings for the patient about the medication (e.g. \"may cause drowsiness\" or \"avoid exposure of skin to direct sunlight or sunlamps\")." ] ;
